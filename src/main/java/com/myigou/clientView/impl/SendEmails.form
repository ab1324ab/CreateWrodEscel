            </constraints>
            <properties>
              <horizontalAlignment value="0"/>
              <text value="邮件发送"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="af678" binding="jpanel" layout-manager="GridLayoutManager" row-count="6" column-count="6" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
